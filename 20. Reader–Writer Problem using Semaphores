#include <stdio.h>
#include <pthread.h>
#include <semaphore.h>

sem_t mutex, wrt;
int readcount = 0;
int data = 0;

void *reader(void *arg)
{
    sem_wait(&mutex);
    readcount++;

    if(readcount == 1)
        sem_wait(&wrt);

    sem_post(&mutex);

    printf("Reader %d reads data = %d\n", *(int*)arg, data);

    sem_wait(&mutex);
    readcount--;

    if(readcount == 0)
        sem_post(&wrt);

    sem_post(&mutex);
}

void *writer(void *arg)
{
    sem_wait(&wrt);

    data++;
    printf("Writer %d writes data = %d\n", *(int*)arg, data);

    sem_post(&wrt);
}

int main()
{
    pthread_t r[3], w[2];
    int id[3]={1,2,3};

    sem_init(&mutex,0,1);
    sem_init(&wrt,0,1);

    pthread_create(&w[0],NULL,writer,&id[0]);
    pthread_create(&r[0],NULL,reader,&id[1]);
    pthread_create(&r[1],NULL,reader,&id[2]);

    pthread_join(w[0],NULL);
    pthread_join(r[0],NULL);
    pthread_join(r[1],NULL);

    return 0;
}
