#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <sys/stat.h>
#include <dirent.h>

int main()
{
    int fd;
    struct stat fileStat;
    DIR *d;
    struct dirent *dir;

    fd=open("sample.txt",O_CREAT|O_RDWR,0777);

    write(fd,"Operating System",16);

    lseek(fd,0,SEEK_SET);

    fstat(fd,&fileStat);

    printf("File Size: %ld bytes\n",fileStat.st_size);

    close(fd);

    d=opendir(".");

    printf("\nFiles in current directory:\n");

    while((dir=readdir(d))!=NULL)
        printf("%s\n",dir->d_name);

    closedir(d);
}
